@using System.Linq
@model FutureV.Core.Entities.Car
@{
    if (Model is not null)
    {
        ViewData["Title"] = Model.Name;
    }
}

@if (Model is null)
{
    <section class="container py-5">
        <div class="alert alert-warning">Vehicle not found.</div>
    </section>
    return;
}

@{
    var imageChoices = Model.Images
        .OrderBy(image => image.Id)
        .Select(image => new
        {
            Source = image.GetImageSource(),
            Angle = string.IsNullOrWhiteSpace(image.ViewAngle) ? "Angle" : image.ViewAngle,
            Alt = string.IsNullOrWhiteSpace(image.Description) ? $"{Model.Name} {image.ViewAngle}" : image.Description
        })
        .Where(image => !string.IsNullOrWhiteSpace(image.Source))
        .ToList();
    var primaryImage = imageChoices.FirstOrDefault();
}

<section class="fv-section pt-5">
    <div class="container">
        <div class="fv-page-header">
            <div>
                <p class="fv-section__title">Vehicle detail</p>
                <h1 class="fv-title-xl">@Model.Name</h1>
                @if (!string.IsNullOrWhiteSpace(Model.Tagline))
                {
                    <p class="fv-page__lead">@Model.Tagline</p>
                }
            </div>
            <div class="fv-detail-meta">
                <span>@Model.AutonomyLevel</span>
                <span>@Model.DriveType</span>
                <span>@Model.EnergySystem</span>
            </div>
        </div>

        <div class="fv-detail-page">
            <div class="fv-detail-page__viewer fv-pane">
                <div class="fv-detail-page__stage">
                    <div class="fv-detail-page__frame">
                        @if (primaryImage is not null)
                        {
                            <img src="@primaryImage.Source" alt="@primaryImage.Alt" data-detail-carousel-main />
                        }
                    </div>

                    @if (imageChoices.Count > 1)
                    {
                        <div class="fv-detail-page__thumbs" data-detail-carousel>
                            @foreach (var image in imageChoices)
                            {
                                <button type="button"
                                        class="fv-detail-page__thumb"
                                        data-detail-carousel-thumb
                                        data-image-src="@image.Source"
                                        data-image-alt="@image.Alt"
                                        data-image-caption="@image.Angle"
                                        aria-pressed="@(image == primaryImage ? "true" : "false")">
                                    <img src="@image.Source" alt="@image.Angle" />
                                    <span>@image.Angle</span>
                                </button>
                            }
                        </div>
                    }
                </div>

                <div class="fv-detail-page__strip">
                    <div class="fv-detail-page__chip"><span>Drive</span><strong>@Model.DriveType</strong></div>
                    <div class="fv-detail-page__chip"><span>Range</span><strong>@Model.RangePerCharge km</strong></div>
                    <div class="fv-detail-page__chip"><span>Seats</span><strong>@Model.SeatingCapacity</strong></div>
                    <div class="fv-detail-page__chip"><span>Year</span><strong>@Model.ReleaseYear</strong></div>
                </div>

                <div class="fv-detail-page__specs fv-pane">
                    <div class="fv-pane__title">Specifications</div>
                    <details open>
                        <summary>Performance</summary>
                        <div class="fv-detail-page__spec-grid">
                            <div><span>0-60 mph</span><strong>@Model.ZeroToSixty s</strong></div>
                            <div><span>Top speed</span><strong>@Model.TopSpeed km/h</strong></div>
                            <div><span>Fast charge</span><strong>@Model.FastChargeMinutes min</strong></div>
                            <div><span>Power</span><strong>@Model.PowerOutput</strong></div>
                        </div>
                    </details>
                    <details>
                        <summary>Technology</summary>
                        <div class="fv-detail-page__spec-copy">@Model.AutonomyLevel with @Model.EnergySystem for a calmer, longer-range drive.</div>
                    </details>
                    <details>
                        <summary>Overview</summary>
                        <div class="fv-detail-page__spec-copy">@Model.Narrative</div>
                    </details>
                </div>
            </div>

            <aside class="fv-detail-page__panel fv-pane fv-pane--dark">
                <div>
                    <div class="fv-section__title">@Model.Name</div>
                    <h2 class="fv-title-lg mb-2">@Model.Tagline</h2>
                    <p class="fv-page__lead mb-0">A cleaner presentation with the image first, the trim rail beside it, and the details kept secondary.</p>
                </div>

                <div class="fv-detail-page__price">
                    <span>Cash price</span>
                    <strong>@Model.BasePrice.ToString("C0")</strong>
                </div>

                <div class="fv-detail-page__actions">
                    <a class="fv-btn" asp-controller="Home" asp-action="Contact" asp-route-car="@Model.Name">Request details</a>
                    <a class="fv-btn-outline" asp-controller="Catalog" asp-action="Index">Back to fleet</a>
                </div>

                <div class="fv-detail-page__list">
                    <div class="fv-detail-shell__stat">
                        <span class="fv-detail-shell__stat-label">Autonomy</span>
                        <span class="fv-detail-shell__stat-value">@Model.AutonomyLevel</span>
                    </div>
                    <div class="fv-detail-shell__stat">
                        <span class="fv-detail-shell__stat-label">Energy</span>
                        <span class="fv-detail-shell__stat-value">@Model.EnergySystem</span>
                    </div>
                    <div class="fv-detail-shell__stat">
                        <span class="fv-detail-shell__stat-label">Drive</span>
                        <span class="fv-detail-shell__stat-value">@Model.DriveType</span>
                    </div>
                    <div class="fv-detail-shell__stat">
                        <span class="fv-detail-shell__stat-label">Range</span>
                        <span class="fv-detail-shell__stat-value">@Model.RangePerCharge km</span>
                    </div>
                </div>
            </aside>
        </div>
    </div>
</section>
