@using System.Linq
@model FutureV.Core.Entities.Car
@{
    if (Model is not null)
    {
        ViewData["Title"] = Model.Name;
    }
}

@if (Model is null)
{
    <section class="container py-5">
        <div class="alert alert-warning">Vehicle not found.</div>
    </section>
    return;
}

@{
    var imageChoices = Model.Images
        .OrderBy(image => image.Id)
        .Select(image => new
        {
            Source = image.GetImageSource(),
            Angle = string.IsNullOrWhiteSpace(image.ViewAngle) ? "Angle" : image.ViewAngle,
            Alt = string.IsNullOrWhiteSpace(image.Description) ? $"{Model.Name} {image.ViewAngle}" : image.Description
        })
        .Where(image => !string.IsNullOrWhiteSpace(image.Source))
        .ToList();
    var primaryImage = imageChoices.FirstOrDefault();
}

<section class="fv-section pt-5">
    <div class="container">
        <div class="fv-page-header">
            <div>
                <p class="fv-section__title">Vehicle detail</p>
                <h1 class="fv-title-xl">@Model.Name</h1>
                @if (!string.IsNullOrWhiteSpace(Model.Tagline))
                {
                    <p class="fv-page__lead">@Model.Tagline</p>
                }
            </div>
            <div class="fv-detail-meta">
                <span>@Model.AutonomyLevel</span>
                <span>@Model.DriveType</span>
                <span>@Model.EnergySystem</span>
            </div>
        </div>

        <div class="fv-detail-hero">
            <div class="fv-detail-hero__media">
                @if (primaryImage is not null)
                {
                    <img src="@primaryImage.Source" alt="@primaryImage.Alt" data-detail-carousel-main />
                }

                <div class="fv-detail-hero__overlay">
                    <span class="fv-detail-hero__kicker">Featured vehicle</span>
                    <div class="fv-detail-hero__title">@Model.Name</div>
                    @if (!string.IsNullOrWhiteSpace(Model.Tagline))
                    {
                        <p class="fv-detail-hero__copy mb-0" data-detail-carousel-caption>@Model.Tagline</p>
                    }
                </div>
            </div>

            @if (imageChoices.Count > 1)
            {
                <div class="fv-detail-hero__thumbs" data-detail-carousel>
                    @foreach (var image in imageChoices)
                    {
                        <button type="button"
                                class="fv-detail-hero__thumb"
                                data-detail-carousel-thumb
                                data-image-src="@image.Source"
                                data-image-alt="@image.Alt"
                                data-image-caption="@image.Angle"
                                aria-pressed="@(image == primaryImage ? "true" : "false")">
                            <img src="@image.Source" alt="@image.Angle" />
                            <span>@image.Angle</span>
                        </button>
                    }
                </div>
            }

            <aside class="fv-detail-hero__rail fv-pane fv-pane--dark">
                <div class="fv-detail-shell__assistant">
                    <div class="fv-detail-shell__assistant-title">AI Assistant</div>
                    <p class="fv-detail-shell__assistant-copy">Ask for a comparison, request a viewing, or review the most important specs without clutter.</p>
                </div>

                <div class="fv-detail-hero__price">
                    <span>Starting price</span>
                    <strong>@Model.BasePrice.ToString("C0")</strong>
                </div>

                <div class="fv-detail-shell__actions">
                    <div class="fv-detail-shell__action">
                        <strong>Book a viewing</strong>
                        <span>Pick a time to inspect it</span>
                    </div>
                    <div class="fv-detail-shell__action">
                        <strong>Compare</strong>
                        <span>Check range and speed</span>
                    </div>
                    <div class="fv-detail-shell__action">
                        <strong>Contact</strong>
                        <span>Send a private inquiry</span>
                    </div>
                </div>

                <div class="fv-detail-shell__list">
                    <div class="fv-detail-shell__stat">
                        <span class="fv-detail-shell__stat-label">Range</span>
                        <span class="fv-detail-shell__stat-value">@Model.RangePerCharge km</span>
                    </div>
                    <div class="fv-detail-shell__stat">
                        <span class="fv-detail-shell__stat-label">Top speed</span>
                        <span class="fv-detail-shell__stat-value">@Model.TopSpeed km/h</span>
                    </div>
                    <div class="fv-detail-shell__stat">
                        <span class="fv-detail-shell__stat-label">0-60 mph</span>
                        <span class="fv-detail-shell__stat-value">@Model.ZeroToSixty s</span>
                    </div>
                    <div class="fv-detail-shell__stat">
                        <span class="fv-detail-shell__stat-label">Fast charge</span>
                        <span class="fv-detail-shell__stat-value">@Model.FastChargeMinutes min</span>
                    </div>
                </div>

                <a class="fv-btn w-100" asp-controller="Home" asp-action="Contact" asp-route-car="@Model.Name">Request details</a>
            </aside>
        </div>

        <div class="row g-4 mt-4">
            <div class="col-lg-7">
                <div class="fv-pane">
                    <div class="fv-pane__title">Storyline</div>
                    <p class="fv-pane__info mb-0">@Model.Narrative</p>
                </div>
            </div>
            <div class="col-lg-5">
                <div class="fv-pane fv-pane--dark h-100">
                    <div class="fv-pane__title">Key points</div>
                    <ul class="fv-detail-bullets">
                        <li>@Model.PowerOutput</li>
                        <li>@Model.SeatingCapacity seats for daily use.</li>
                        <li>@Model.ReleaseYear release with a @Model.DriveType setup.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>
