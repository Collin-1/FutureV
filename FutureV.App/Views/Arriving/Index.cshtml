@{
    ViewData["Title"] = "Coming Soon";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="container py-5">
    <div class="row mb-4">
        <div class="col-lg-8 mx-auto text-center">
            <div class="fv-section__title">Upcoming line</div>
            <h1 class="fv-title-xl mb-3">New concepts are staged for the next reveal.</h1>
            <p class="fv-page__lead mx-auto">Instead of one giant poster, this page now reads like a launch sheet: each concept gets a clear identity, a date, and a short pitch.</p>
        </div>
    </div>
    @{
    var arrivingCars = new List<dynamic> {
        new {
            Name = "FutureV AeroX",
            ImageUrl = "/Images/arriving1.png",
            TopLeft = "A low, efficient coupe built around a carbon chassis and active aero.",
            TopCenter = "AeroX is the most performance-focused concept in the next wave, tuned for range, stability, and visual impact.",
            TopRight = "Target range: 900 km and fast charging in under 15 minutes.",
            MiddleLeft = "Adaptive rear wing, dynamic shutters, and a diffused underbody keep the body planted at speed.",
            MiddleRight = "A clean cockpit layout leaves the driving experience calm rather than cluttered.",
            BottomCenter = "Arriving Q2 2036"
        },
        new {
            Name = "FutureV Urbanite",
            ImageUrl = "/Images/arriving2.png",
            TopLeft = "A compact city model designed to park anywhere and feel easy on day one.",
            TopCenter = "Urbanite focuses on flexible seating, visibility, and a cabin that doubles as a workspace.",
            TopRight = "Wireless charging and a 360° sensor suite keep the car effortless in dense traffic.",
            MiddleLeft = "Modular interior formats let you switch between passengers, cargo, or a quiet solo commute.",
            MiddleRight = "Level 5 autonomy is tuned for city infrastructure and short-trip convenience.",
            BottomCenter = "Arriving Q3 2036"
        },
        new {
            Name = "FutureV Terra",
            ImageUrl = "/Images/arriving3.png",
            TopLeft = "An all-terrain electric SUV for drivers who want polish on-road and confidence off it.",
            TopCenter = "Terra mixes adaptive ride height, solar support, and durable materials in a premium utility package.",
            TopRight = "Off-road navigation, solar range support, and a reinforced underbody extend the car's scope.",
            MiddleLeft = "Adaptive suspension shifts ride height and damping to suit highway or trail use.",
            MiddleRight = "The interior uses sustainable materials that are durable enough for real daily life.",
            BottomCenter = "Arriving Q4 2036"
        },
        new {
            Name = "FutureV Luxora",
            ImageUrl = "/Images/arriving4.png",
            TopLeft = "The flagship sedan in the range: calm, quiet, and formally finished.",
            TopCenter = "Luxora is designed to feel like private aviation, from the seating layout to the glass roof.",
            TopRight = "Biometric access, adaptive comfort settings, and silent drive tuning complete the package.",
            MiddleLeft = "Rear executive seating, soft ambient lighting, and a panoramic smart roof define the cabin.",
            MiddleRight = "Voice and gesture controls keep the interface clean and uncluttered.",
            BottomCenter = "Arriving 2037"
        }
    };
}

@foreach (var car in arrivingCars)
{
    <section class="fv-arriving-hero mb-5">
        <img src="@car.ImageUrl" alt="@car.Name" />
        <div class="fv-arriving-overlay">
            <div class="fv-arriving-pos fv-arriving-top-left">
                <div class="fv-arriving-title">@car.Name</div>
                <div class="fv-arriving-title-line"></div>
            </div>
            <div class="fv-arriving-pos fv-arriving-top-right">
                <span class="fv-arriving-chip">@car.TopRight</span>
            </div>
            <div class="fv-arriving-pos fv-arriving-middle-left">
                <div class="fv-arriving-detail">@car.TopLeft</div>
            </div>
            <div class="fv-arriving-pos fv-arriving-middle-right">
                <div class="fv-arriving-detail">@car.MiddleRight</div>
            </div>
            <div class="fv-arriving-pos fv-arriving-bottom-center">
                <div class="fv-arriving-note">@car.TopCenter</div>
                <div class="fv-arriving-desc">@car.BottomCenter</div>
                <div class="fv-arriving-detail mt-3">@car.MiddleLeft</div>
            </div>
        </div>
    </section>
}

<div class="container my-5">
    <div class="row">
        <div class="col-lg-8 mx-auto text-center">
            <a asp-controller="Catalog" asp-action="Index" class="fv-btn px-5 py-3 mt-3">See current models</a>
        </div>
    </div>
</div>
