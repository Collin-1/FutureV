@{
    ViewData["Title"] = "Coming Soon";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@{
    var arrivingCars = new[]
    {
        new {
            Name = "FutureV AeroX",
            ImageUrl = "/Images/arriving1.png",
            Label = "Performance coupe",
            Summary = "Carbon bodywork, active aero, and a range-first powertrain tuned for fast, confident travel.",
            Range = "900 km",
            Arrival = "Q2 2036",
            Drive = "Adaptive aero"
        },
        new {
            Name = "FutureV Urbanite",
            ImageUrl = "/Images/arriving2.png",
            Label = "City shuttle",
            Summary = "A compact, autonomous city car with a flexible cabin and effortless parking geometry.",
            Range = "620 km",
            Arrival = "Q3 2036",
            Drive = "Level 5 autonomy"
        },
        new {
            Name = "FutureV Terra",
            ImageUrl = "/Images/arriving3.png",
            Label = "Adventure SUV",
            Summary = "A premium all-terrain model with adaptive suspension, solar support, and a durable interior.",
            Range = "780 km",
            Arrival = "Q4 2036",
            Drive = "All-terrain control"
        },
        new {
            Name = "FutureV Luxora",
            ImageUrl = "/Images/arriving4.png",
            Label = "Flagship sedan",
            Summary = "Private-aviation comfort, biometric access, and a refined cabin built around calm luxury.",
            Range = "840 km",
            Arrival = "2037",
            Drive = "Executive drive"
        }
    };
}

<section class="fv-section pt-5">
    <div class="container">
        <div class="fv-page-header mb-4">
            <div>
                <div class="fv-section__title">Arrival board</div>
                <h1 class="fv-title-xl mb-0">The next drop is staged like a live control room.</h1>
                <p class="fv-page__lead mt-3">This page replaces the old full-screen posters with a dashboard-inspired launch board, a concept grid, and a clear rollout timeline.</p>
            </div>
            <div class="fv-detail-meta">
                <span>@arrivingCars.Length upcoming models</span>
                <span>Mixed utility and luxury</span>
                <span>FutureV launch pipeline</span>
            </div>
        </div>

        <div class="fv-arriving-board mb-4">
            <div class="fv-arriving-board__hero">
                <img src="/Images/Gemini_Generated_Image_s058vms058vms058.png" alt="FutureV arriving hero" />
                <div class="fv-arriving-board__copy">
                    <div class="fv-arriving-board__kicker">Launch preview</div>
                    <div class="fv-arriving-board__title">Four concepts. One clean pipeline.</div>
                    <p class="fv-arriving-board__summary">AeroX, Urbanite, Terra, and Luxora now sit in a single launch board so the page feels more like a real product dashboard.</p>
                </div>
            </div>
            <div class="fv-arriving-board__panel">
                <div class="fv-detail-shell__assistant">
                    <div class="fv-detail-shell__assistant-title">AI Assistant</div>
                    <p class="fv-detail-shell__assistant-copy">Choose a concept, review its role in the line-up, and preview the launch timing.</p>
                </div>
                <div class="fv-arriving-board__actions">
                    <div class="fv-arriving-board__action"><strong>Book a preview</strong><span>See the concept in detail</span></div>
                    <div class="fv-arriving-board__action"><strong>Analysis</strong><span>Compare range and focus</span></div>
                    <div class="fv-arriving-board__action"><strong>Insurance</strong><span>Preview coverage options</span></div>
                    <div class="fv-arriving-board__action"><strong>Payment</strong><span>Estimate price positioning</span></div>
                </div>
                <div class="fv-detail-shell__sendbar">
                    <input type="text" value="Ask about the next arriving model" aria-label="Arrival assistant prompt" readonly />
                    <button type="button">Send</button>
                </div>
                <div class="fv-arriving-strip">
                    <div class="fv-arriving-strip__item">
                        <div class="fv-arriving-strip__label">Hero</div>
                        <div class="fv-arriving-strip__body">AeroX</div>
                    </div>
                    <div class="fv-arriving-strip__item">
                        <div class="fv-arriving-strip__label">Urban</div>
                        <div class="fv-arriving-strip__body">Urbanite</div>
                    </div>
                    <div class="fv-arriving-strip__item">
                        <div class="fv-arriving-strip__label">Utility</div>
                        <div class="fv-arriving-strip__body">Terra</div>
                    </div>
                    <div class="fv-arriving-strip__item">
                        <div class="fv-arriving-strip__label">Luxury</div>
                        <div class="fv-arriving-strip__body">Luxora</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="fv-arriving-grid">
            @foreach (var car in arrivingCars)
            {
                <article class="fv-arriving-card">
                    <div class="fv-arriving-card__image">
                        <img src="@car.ImageUrl" alt="@car.Name" />
                    </div>
                    <div class="fv-arriving-card__body">
                        <div class="fv-section__title mb-2">@car.Label</div>
                        <h2 class="fv-arriving-card__title">@car.Name</h2>
                        <p class="fv-arriving-card__copy">@car.Summary</p>
                        <div class="fv-arriving-card__meta">
                            <span class="fv-arriving-card__badge">@car.Range</span>
                            <span class="fv-arriving-card__badge">@car.Drive</span>
                            <span class="fv-arriving-card__badge">@car.Arrival</span>
                        </div>
                    </div>
                </article>
            }
        </div>

        <div class="row g-4 mt-4">
            <div class="col-lg-8">
                <div class="fv-pane fv-pane--dark h-100">
                    <div class="fv-pane__title">Rollout notes</div>
                    <p class="fv-pane__info mb-0">The arriving page now works as a launch board instead of a long stacked scroll. Each model has a clearer role, a stronger image block, and more useful supporting text.</p>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="fv-panel h-100">
                    <div class="fv-panel__title">Next step</div>
                    <div class="fv-panel__body">Use the catalog to explore what is already available, then return here to track what is about to land.</div>
                </div>
            </div>
        </div>

        <div class="text-center mt-5">
            <a asp-controller="Catalog" asp-action="Index" class="fv-btn px-5 py-3">See current models</a>
        </div>
    </div>
</section>
