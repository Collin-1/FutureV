@{
    ViewData["Title"] = "FutureV";
}

<section class="fv-hero fv-hero--video">
    <video class="fv-hero__video" autoplay muted loop playsinline preload="auto" aria-hidden="true">
        <source src="/videos/Futuristic Car Flies Through City.mp4" type="video/mp4" />
    </video>
    <div class="container">
        <div class="row align-items-end g-5">
            <div class="col-lg-7">
                <div class="fv-hero__content">
                    <p class="fv-hero__kicker">FutureV automobile studio</p>
                    <h1 class="fv-hero__title">Cars that feel curated, not configured.</h1>
                    <p class="fv-hero__desc">FutureV presents a refined electric fleet with premium materials, intelligent driving systems, and a buying experience shaped like a design magazine rather than a database.</p>
                    <div class="fv-hero__cta">
                        <a class="fv-btn" asp-controller="Catalog" asp-action="Index">Browse fleet</a>
                        <a class="fv-btn-outline" asp-controller="Home" asp-action="Contact">Speak with a curator</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-5">
                <div class="fv-metric-grid">
                    <div class="fv-metric-card">
                        <span>Collections</span>
                        <strong>3 concept lines</strong>
                    </div>
                    <div class="fv-metric-card">
                        <span>Range</span>
                        <strong>Up to 1 050 km</strong>
                    </div>
                    <div class="fv-metric-card">
                        <span>Autonomy</span>
                        <strong>Level 5 pilotage</strong>
                    </div>
                    <div class="fv-metric-card">
                        <span>Charge</span>
                        <strong>7 to 12 minutes</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="fv-section">
    <div class="container">
        <div class="row align-items-end mb-4">
            <div class="col-lg-8">
                <div class="fv-section__title">Car categories</div>
                <h2 class="fv-title-lg mb-0">Choose the mood before you choose the model.</h2>
            </div>
        </div>
        <div class="row g-4">
            <div class="col-md-6 col-xl-3">
                <div class="fv-image-card fv-image-card--tall">
                    <img src="/Images/cat-hero.png" alt="Luxury category" />
                    <div class="fv-image-overlay">
                        <p class="fv-section__title mb-2">Luxury</p>
                        <h3 class="h2 mb-2">Executive comfort</h3>
                        <a class="fv-pill-link" asp-controller="Catalog" asp-action="Index">Explore</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="fv-image-card fv-image-card--tall">
                    <img src="/Images/solid-state-graphene-batteries.png" alt="Performance category" />
                    <div class="fv-image-overlay">
                        <p class="fv-section__title mb-2">Performance</p>
                        <h3 class="h2 mb-2">High-output power</h3>
                        <a class="fv-pill-link" asp-controller="Catalog" asp-action="Index">Explore</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="fv-image-card fv-image-card--tall">
                    <img src="/Images/level-5-autonomous-ai.png" alt="Autonomous category" />
                    <div class="fv-image-overlay">
                        <p class="fv-section__title mb-2">Autonomy</p>
                        <h3 class="h2 mb-2">AI-led travel</h3>
                        <a class="fv-pill-link" asp-controller="Discover" asp-action="Index">Explore</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="fv-image-card fv-image-card--tall">
                    <img src="/Images/sustainable-smart-materials.png" alt="Utility category" />
                    <div class="fv-image-overlay">
                        <p class="fv-section__title mb-2">Utility</p>
                        <h3 class="h2 mb-2">Built for daily use</h3>
                        <a class="fv-pill-link" asp-controller="Catalog" asp-action="Index">Explore</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="fv-section fv-section--contrast">
    <div class="container">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3 mb-4">
            <div>
                <div class="fv-section__title">Trend vehicles</div>
                <h2 class="fv-title-lg mb-0">The current shortlist.</h2>
            </div>
            <a class="fv-btn-outline" asp-controller="Catalog" asp-action="Index">View all concepts</a>
        </div>
        <div class="row g-4">
            <div class="col-md-6 col-xl-3">
                <article class="fv-card h-100">
                    <div class="fv-card__visual"><img src="/Images/ariving.png" alt="Nova Edge concept" /></div>
                    <div class="fv-card__body">
                        <span class="fv-chip">Nova Edge</span>
                        <h3 class="fv-card__title">Precision and speed</h3>
                        <p class="fv-card__desc">A sharp, luxury performance coupe with a focus on range, acceleration, and a deeply cinematic cabin.</p>
                    </div>
                </article>
            </div>
            <div class="col-md-6 col-xl-3">
                <article class="fv-card h-100">
                    <div class="fv-card__visual"><img src="/Images/autonomous-intelligence.png" alt="Aurora Sphere concept" /></div>
                    <div class="fv-card__body">
                        <span class="fv-chip">Aurora Sphere</span>
                        <h3 class="fv-card__title">Quiet intelligence</h3>
                        <p class="fv-card__desc">The holosphere cabin and magnetic glide tech turn every trip into a private lounge on wheels.</p>
                    </div>
                </article>
            </div>
            <div class="col-md-6 col-xl-3">
                <article class="fv-card h-100">
                    <div class="fv-card__visual"><img src="/Images/electric.png" alt="Chrono Flux concept" /></div>
                    <div class="fv-card__body">
                        <span class="fv-chip">Chrono Flux</span>
                        <h3 class="fv-card__title">Time-smooth motion</h3>
                        <p class="fv-card__desc">A fast, agile concept built to compress long drives into a cleaner and calmer experience.</p>
                    </div>
                </article>
            </div>
            <div class="col-md-6 col-xl-3">
                <article class="fv-card h-100">
                    <div class="fv-card__visual"><img src="/Images/crafted-interior.png" alt="Luxora concept" /></div>
                    <div class="fv-card__body">
                        <span class="fv-chip">Luxora</span>
                        <h3 class="fv-card__title">First-class interiors</h3>
                        <p class="fv-card__desc">A polished cabin language where materials, lighting, and touchpoints feel tailored to the driver.</p>
                    </div>
                </article>
            </div>
        </div>
    </div>
</section>

<section class="fv-section">
    <div class="container">
        <div class="row g-4 align-items-stretch">
            <div class="col-lg-7">
                <div class="fv-image-card fv-image-card--large h-100">
                    <img src="/Images/bottom.png" alt="FutureV showcase vehicle" />
                    <div class="fv-image-overlay">
                        <p class="fv-section__title mb-2">Showcase</p>
                        <h3 class="fv-title-lg mb-3">Clean lines, strong stance, premium finish.</h3>
                        <p class="mb-4">Our newest concepts combine high-output electric performance with a calmer, more luxurious user experience.</p>
                        <div class="d-flex gap-3 flex-wrap">
                            <a class="fv-btn" asp-controller="Catalog" asp-action="Index">Open catalog</a>
                            <a class="fv-btn-outline" asp-controller="Home" asp-action="Contact">Plan a viewing</a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-5">
                <div class="fv-image-card fv-image-card--tall h-100">
                    <img src="/Images/cat-hero.png" alt="FutureV city vehicle" />
                    <div class="fv-image-overlay">
                        <p class="fv-section__title mb-2">Urban focus</p>
                        <h3 class="h2 mb-3">Built to look good in traffic and on arrival.</h3>
                        <p class="mb-4">A smaller, smarter vehicle profile designed for dense cities, short trips, and effortless parking.</p>
                        <a class="fv-pill-link" asp-controller="Discover" asp-action="Index">See the design notes</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="fv-section fv-cta-section">
    <div class="container">
        <div class="fv-image-card fv-image-card--cta">
            <img src="/Images/Gemini_Generated_Image_s058vms058vms058.png" alt="FutureV highlight" />
            <div class="fv-image-overlay fv-image-overlay--center">
                <div class="fv-section__title mb-3">Book a preview</div>
                <h2 class="fv-title-lg mb-4">Want a private walk-through of the fleet?</h2>
                <p class="fv-hero__desc mx-auto mb-4" style="max-width: 620px;">Tell us which model speaks to you and we’ll tailor the discussion around design, range, technology, or admin access for your own collection.</p>
                <div class="d-flex gap-3 justify-content-center flex-wrap">
                    <a class="fv-btn" asp-controller="Home" asp-action="Contact">Get in touch</a>
                    <a class="fv-btn-outline" asp-controller="Catalog" asp-action="Index">Browse concepts</a>
                </div>
            </div>
        </div>
    </div>
</section>
